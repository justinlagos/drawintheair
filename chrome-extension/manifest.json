{
    "manifest_version": 3,
    "name": "Draw in the Air",
    "version": "1.0.0",
    "description": "Launch Draw in the Air — a hand-tracking learning app where kids trace letters, numbers, and shapes using webcam gestures.",
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "action": {
        "default_title": "Open Draw in the Air",
        "default_icon": {
            "16": "icons/icon-16.png",
            "48": "icons/icon-48.png",
            "128": "icons/icon-128.png"
        }
    },
    "background": {
        "service_worker": "service-worker.js"
    }
}