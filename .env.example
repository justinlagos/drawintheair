# ─────────────────────────────────────────────────────────────────────────────
# Draw in the Air — Environment Variables Template
#
# Copy this file to .env and fill in real values for local development.
# NEVER commit .env — it is listed in .gitignore.
#
# Production deployments (Vercel, etc.) should set these as platform
# environment variables, not from a committed .env file.
# ─────────────────────────────────────────────────────────────────────────────

# Admin dashboard PIN — required to access /admin
# Use a strong PIN (8+ characters, mix of letters and numbers).
# If this variable is not set at build time, the admin panel is
# disabled and all login attempts are rejected.
VITE_ADMIN_PIN=your-strong-pin-here

# Google Apps Script deployment URL for the admin analytics endpoint.
# IMPORTANT: The original deployment URL was exposed in git history.
# You must create a new deployment in your Apps Script project and
# use its fresh URL here. The old URL must be revoked/deleted.
# How to create a new deployment: open your Apps Script project →
# Deploy → Manage Deployments → New Deployment.
VITE_SHEETS_ENDPOINT=https://script.google.com/macros/s/YOUR_NEW_DEPLOYMENT_ID/exec

# Build version label (displayed in admin UI footer)
VITE_BUILD_VERSION=1.0.0

# Platform URL for teacher authentication links
# Used in HeaderNav and Footer to link to the authentication platform
# For development: http://localhost:3000
# For production: https://app.drawintheair.com (or your production URL)
VITE_PLATFORM_URL=http://localhost:3000

# ─── Form Submission Endpoint ──────────────────────────────────────────────
# Unified form submission endpoint (emails to partnership@drawintheair.com)
# Points to the platform API route. Falls back to Google Sheets if unset.
VITE_FORM_ENDPOINT=https://app.drawintheair.com/api/form-submission

# ─── Class Mode (Supabase) ──────────────────────────────────────────────────
# Required for Class Mode (live classroom sessions).
# Get these from your Supabase project dashboard → Settings → API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Observability (Sentry / PostHog) ───────────────────────────────────────
# All three observability vars are OPTIONAL. If a key is missing the
# corresponding system silently no-ops — the app keeps working, and
# the existing LIOS analytics pipeline is unaffected.
#
# Privacy contract: no child names, no raw camera frames, no PII.
# Implementation enforces this in src/lib/observability/{sentry,posthog}.ts.

# Sentry DSN — frontend error tracking.
# Get from Sentry → Project Settings → Client Keys (DSN).
# Leave blank in dev to disable Sentry entirely.
VITE_SENTRY_DSN=

# Sentry performance/latency sampling rate (0..1). Drives page-load +
# request latency data — the signal that reveals slow regions like
# Nigeria. Default 0.1 (10% of sessions). Set higher temporarily while
# investigating, lower to save quota.
VITE_SENTRY_TRACES_RATE=0.1

# Sentry session replay. OFF unless set to exactly "on". This is a
# children's webcam app, so replay (when enabled) runs ONLY on errors
# and masks ALL text + blocks ALL media — it can never capture faces.
# Leave blank/unset to keep replay fully disabled (recommended default).
VITE_SENTRY_REPLAY=

# PostHog project API key — product analytics.
# Get from PostHog → Project Settings → Project API Key.
# Use the PUBLIC key (the one safe to ship in a frontend bundle).
VITE_POSTHOG_KEY=

# PostHog host — where events are sent. Use the EU host for GDPR.
#   EU:  https://eu.i.posthog.com
#   US:  https://us.i.posthog.com
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Environment label — appears in Sentry + PostHog event tags.
# Common values: development | staging | production
VITE_APP_ENV=development

# App version — pinned at build time, used as Sentry release tag and
# PostHog event property. Set this from CI to the commit SHA or
# semver tag so we can attribute errors to a specific deploy.
VITE_APP_VERSION=0.0.0-dev

# ─── Uptime monitoring (BetterStack) ────────────────────────────────────────
# BetterStack is configured in its OWN dashboard, not via these build-time
# vars — it pings the live site from multiple global regions (including
# Africa). No key is shipped in the frontend. See docs/NIGERIA_RELIABILITY_
# REPORT.md → "Observability" for the exact monitors to create:
#   1. HTTP monitor → https://drawintheair.com/            (apex, what users hit)
#   2. HTTP monitor → https://www.drawintheair.com/        (www → 308 path)
#   3. HTTP monitor → https://drawintheair.com/health.json (lightweight heartbeat)
# Set the checking regions to include Lagos/Africa so a Nigeria-specific
# routing failure pages you even when the EU/US edge is healthy.
